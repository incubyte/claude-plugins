---
import ThemeToggle from './ThemeToggle.astro';
import { bookTitle } from '../book.config';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] dark:border-[#333] bg-[var(--color-cream)]/95 dark:bg-[var(--color-charcoal)]/95 backdrop-blur-sm">
  <div class="max-w-4xl mx-auto px-4 md:px-8 h-14 flex items-center justify-between">
    <a href={base} class="text-sm font-semibold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] hover:text-[var(--color-terracotta)] transition-colors">
      {bookTitle}
    </a>
    <ThemeToggle />
  </div>
</header>
