{
  "description": "Auto-approve bee state updates so developers are not prompted for every slice transition",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/approve-bee-state.sh"
          }
        ]
      }
    ]
  }
}
